# ─────────────────────────────────────────────────────────────────────────────
#  EventPass v2 — Environment Variables
#  Copy to .env and fill in every value before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Long random secret — rotate between events to invalidate all QR codes.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-hex-character-random-string

# Admin dashboard password.
ADMIN_PASSWORD=replace-with-strong-password

# SQLite path. Railway: attach Volume at /data and use path below.
# Local dev: sqlite:///./event_system.db
DATABASE_URL=sqlite:////data/event_system.db

# Gmail account for sending QR codes.
EMAIL_USER=your_event_email@gmail.com

# Gmail App Password (NOT your login password).
# Enable 2FA then generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_16_character_app_password

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# EVENT_NAME=EventPass
# PORT is set automatically by Railway
